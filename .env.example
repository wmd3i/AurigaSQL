# Optional development overrides. Product model profiles are normally configured
# in the AurigaSQL Settings UI and stored outside the repository.

# Runtime/resource locations
AURIGASQL_USER_DATA_DIR=
AURIGASQL_RESOURCES_DIR=
AURIGASQL_DATASETS_DIR=

# Source BFF
AURIGASQL_BFF_PORT=6003
AURIGASQL_BFF_LOG_LEVEL=warning

# Optional local GGUF runtime overrides
AURIGASQL_LLAMA_SERVER_PATH=
AURIGASQL_LOCAL_MODEL_PORT=6021
AURIGASQL_LOCAL_MODEL_DOWNLOAD_WORKERS=4

# Optional model used when automatic data-source routing has no selected profile
DB_ROUTER_MODEL=
LITELLM_API_BASE=
LITELLM_API_KEY=

# Optional verbose local JSONL logging of prompts, responses, and tool calls.
# Leave disabled for normal use because logs may contain user or database data.
AURIGASQL_ENABLE_LLM_LOGGER=false
